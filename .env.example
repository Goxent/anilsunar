# ----- Gemini AI (FREE from Google AI Studio — aistudio.google.com) -----------
# THIS IS REQUIRED — all AI features (AI Research, Content Studio, AI Digest) use this
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ----- Server-only Secrets (NO VITE_ prefix) ----------------
# These are NEVER sent to the browser. Used in Vercel API routes
# and GitHub Actions only.

# Claude / Anthropic (OPTIONAL — only needed when you subscribe to Anthropic API)
# Leave blank for now — app works without this
ANTHROPIC_API_KEY=

# Sasto Share / NepseAlpha credentials (for the scraper bot)
SASTO_EMAIL=your_nepsealpha_email@example.com
SASTO_PASSWORD=your_nepsealpha_password

# Email (Resend.com)
RESEND_API_KEY=your_resend_api_key
TO_EMAIL=anil99senchury@gmail.com

# Vercel sync endpoint protection
SYNC_SECRET_TOKEN=any_random_strong_string_here

# Firebase Admin SDK (JSON string — used by sync-to-firestore.mjs)
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Then paste the entire JSON as a single line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"app-anil-sunar",...}

# Legacy — no longer required (auth now uses Firebase)
# VITE_DASHBOARD_PASSWORD=