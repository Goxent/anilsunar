    "test-email": "node scripts/test-email.mjs",
    "setup-scheduler": "scripts\\scheduler-setup.bat",
    "remove-scheduler": "scripts\\scheduler-remove.bat",
    "auto-sync": "node scripts/auto-sync.js",
    "deploy": "npm run build && gh-pages -d dist"
