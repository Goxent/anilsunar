  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "check-env": "node scripts/check-env.mjs",
    "omni-sync": "node scripts/omni-crawler.mjs",
    "debug-bot": "cross-env DEBUG_BOT=true node scripts/omni-crawler.mjs",
