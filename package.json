    "notice-email": "node scripts/notice-notifier.mjs",
    "notice-sync": "node scripts/notice-scraper.mjs && node scripts/notice-ai-writer.mjs",
    "cloud-sync": "node scripts/sync-to-firestore.mjs",
    "full-sync": "node scripts/omni-crawler.mjs && node scripts/notice-scraper.mjs && node scripts/notice-ai-writer.mjs && node scripts/ai-digest.mjs",
