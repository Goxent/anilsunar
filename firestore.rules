rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users — users read/write own doc, admins read/write all
    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    // Per-user sub-collections (portfolio, watchlist, content)
    match /users/{userId}/data/{docId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    // Sasto intelligence records — admin only
    match /sasto_records/{docId} {
      allow read, write: if isAdmin();
    }

    // Market data — all authenticated users can read, only admins write
    match /market_data/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Newsletter subscribers — public can create (subscribe), admins manage
    match /subscribers/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
